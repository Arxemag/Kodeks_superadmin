DB_URL=
PG_HOST=localhost
PG_PORT=5432
PG_USERNAME=user
PG_PASSWORD=password
PG_DATABASE=test_base
POOL_SIZE=10
POOL_TIMEOUT=30
# Имена таблиц БД (опционально; по умолчанию reg_services, department_service_mapping)
# DB_TABLE_REG_SERVICES=reg_services
# DB_TABLE_DEPARTMENT_MAPPING=department_service_mapping

ADMIN_LOGIN=kodeks
ADMIN_PASSWORD=skedoks

HTTP_TIMEOUT=10
LOG_LEVEL=INFO
# For deep troubleshooting set: LOG_LEVEL=DEBUG
# Порт HTTP-сервера Auth API (main.py)
PORT=8000
AUTH_SERVICE_URL=http://127.0.0.1:8000

# Kafka. Для Docker: брокер на хосте — host.docker.internal:9092 (Windows/Mac)
# Единый worker (main_unified_worker.py): одна группа KAFKA_GROUP_ID, подписка на все топики.
KAFKA_BROKER=127.0.0.1:9092
KAFKA_BOOTSTRAP_SERVERS=

# Одна consumer group для всех топиков (unified worker)
KAFKA_GROUP_ID=superadmin-workers

# Топики (разные, обрабатываются одним воркером по record.topic)
KAFKA_CREATE_TOPIC=create-user
KAFKA_UPDATE_TOPIC=update-user
KAFKA_UPDATE_DEPARTMENTS_TOPIC=update-user-departments
KAFKA_DLQ_TOPIC=users-dlq
KAFKA_INIT_COMPANY_TOPIC=init_company
KAFKA_INIT_COMPANY_DLQ_TOPIC=init_company-dlq
KAFKA_ENABLE_REG_COMPANY_TOPIC=enable_reg_company
KAFKA_DISABLE_REG_COMPANY_TOPIC=disable_reg_company

KAFKA_MAX_CONCURRENCY=200
KAFKA_POLL_TIMEOUT_MS=500
KAFKA_MAX_BATCH=500

USERS_RETRY_ATTEMPTS=3
USERS_RETRY_BASE_DELAY=0.2
USERS_RETRY_MAX_DELAY=3.0

# Метрики единого воркера (порт 9100)
UNIFIED_WORKER_METRICS_PORT=9100

# Hard timeout for whole /auth/login operation
AUTH_HARD_TIMEOUT=2
AUTH_HARD_TIMEOUT_DEBUG=20
